# postgres
POSTGRES_PASSWORD=your-super-secret-password
POSTGRES_DB=postgres
POSTGRES_PORT=5432

# btrfs volume
BTRFS_MOUNT=/mnt/pgdata
BTRFS_LOOPBACK_SIZE=10G
BTRFS_LOOPBACK_PATH=/var/lib/supabase-branching/btrfs.img

# build settings
SUPABASE_POSTGRES_REF=develop
IMAGE_NAME=supabase-postgres-branching
IMAGE_TAG=latest

# connection
PGHOST=localhost
PGUSER=postgres
